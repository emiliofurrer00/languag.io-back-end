{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=languagio;Username=postgres;Password=postgres"
  },
  "Authentication": {
    "Kinde": {
      "Authority": "https://languagio.kinde.com",
      "Audience": "languag.io.com"
    }
  },
  "ProfileImages": {
    "KeyPrefix": "profile-pictures",
    "MaxUploadBytes": 524288,
    "UploadTtlSeconds": 120
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://languagio.vercel.app"
    ]
  },
  "RequestLimits": {
    "MaxBodyBytes": 1048576
  },
  "ApplyMigrationsOnStartup": false,
  "AllowedHosts": "*"
}
