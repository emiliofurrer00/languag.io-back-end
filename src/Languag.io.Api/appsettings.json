{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Kinde": {
      "Authority": "https://languagio.kinde.com",
      "Audience": "languag.io.com"
    }
  },
  "ProfileImages": {
    "KeyPrefix": "profile-pictures",
    "MaxUploadBytes": 524288,
    "UploadTtlSeconds": 120
  },
  "OpenAI": {
    "TtsModel": "gpt-4o-mini-tts",
    "TtsVoice": "cedar",
    "TtsSpeed": "0.9",
    "TtsInstructionsVersion": "language-learning-v1"
  },
  "AudioStorage": {
    "KeyPrefix": "audio/tts"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://languagio.vercel.app"
    ]
  },
  "RequestLimits": {
    "MaxBodyBytes": 1048576
  },
  "ApplyMigrationsOnStartup": false,
  "AllowedHosts": "*"
}
